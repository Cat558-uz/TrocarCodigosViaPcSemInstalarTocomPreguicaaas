local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")

local MAX_WALKSPEED = 36
local MAX_JUMPPOWER = 80
local MAX_AIR_JUMPS = 2

local Blacklist = {
	["dex"] = true,
	["infinity yield"] = true,
	["spy remote"] = true,
	["simplespy for mobile"] = true,
	["hydroxide"] = true,
	["synapse"] = true,
	["krnl"] = true,
	["fluxus"] = true,
	["delta"] = true,
	["executor"] = true,
	["arceus"] = true,
	["esp"] = true
}

local function IsBlacklisted(text)
	if not text then
		return false
	end

	text = string.lower(tostring(text))
	text = text:gsub("%s+", " ")
	text = text:gsub("^%s+", "")
	text = text:gsub("%s+$", "")

	return Blacklist[text] == true
end

local function CheckObject(obj, player)
	if not obj then
		return
	end

	if IsBlacklisted(obj.Name) then
		player:Kick("Exploiting | Code : 4")
		return
	end

	if obj:IsA("ScreenGui") then
		pcall(function()
			if IsBlacklisted(obj.DisplayName) then
				player:Kick("Exploiting | Code : 5")
			end
		end)
	end

	if obj:IsA("TextLabel")
	or obj:IsA("TextButton")
	or obj:IsA("TextBox") then
		pcall(function()
			if IsBlacklisted(obj.Text) then
				player:Kick("Exploiting | Code : 6")
			end
		end)
	end
end

local function StartGuiDetection(player)
	for _, obj in ipairs(CoreGui:GetDescendants()) do
		CheckObject(obj, player)
	end

	CoreGui.DescendantAdded:Connect(function(obj)
		task.wait(0.5)
		CheckObject(obj, player)
	end)
end

local function DetectInfinityJump(player, humanoid, root)
	local airJumps = 0
	local lastJump = 0

	humanoid.StateChanged:Connect(function(_, newState)
		if newState == Enum.HumanoidStateType.Landed
		or newState == Enum.HumanoidStateType.Running then
			airJumps = 0
		elseif newState == Enum.HumanoidStateType.Jumping then
			local now = tick()

			if humanoid.FloorMaterial == Enum.Material.Air then
				if math.abs(root.AssemblyLinearVelocity.Y) > 80 then
					return
				end

				if now - lastJump < 1 then
					airJumps += 1

					if airJumps >= MAX_AIR_JUMPS then
						player:Kick("Infinity Jump Detected | Code : 7")
					end
				end
			end

			lastJump = now
		end
	end)
end

local function HasFlyObjects(character)
	for _, obj in ipairs(character:GetDescendants()) do
		if obj:IsA("BodyVelocity")
		or obj:IsA("BodyGyro")
		or obj:IsA("BodyPosition")
		or obj:IsA("LinearVelocity")
		or obj:IsA("VectorForce")
		or obj:IsA("AlignPosition")
		or obj:IsA("AlignOrientation") then
			return true
		end
	end

	return false
end

local function DetectFly(player, character, humanoid, root)
	local airTime = 0

	while character.Parent do
		if humanoid.FloorMaterial == Enum.Material.Air then
			airTime += 1

			local velocityY = math.abs(root.AssemblyLinearVelocity.Y)

			if airTime >= 4 then
				if velocityY < 2 and HasFlyObjects(character) then
					player:Kick("Fly Detected | Code : 3")
					break
				end
			end
		else
			airTime = 0
		end

		task.wait(1)
	end
end

local function CheckCharacter(player, character)
	local humanoid = character:WaitForChild("Humanoid", 5)
	local root = character:WaitForChild("HumanoidRootPart", 5)

	if not humanoid or not root then
		return
	end

	DetectInfinityJump(player, humanoid, root)

	task.spawn(function()
		DetectFly(player, character, humanoid, root)
	end)

	while character.Parent do
		if humanoid.WalkSpeed > MAX_WALKSPEED then
			player:Kick("Cheat Detected | Code : 1")
			break
		end

		if humanoid.UseJumpPower and humanoid.JumpPower > MAX_JUMPPOWER then
			player:Kick("Cheat Detected | Code : 2")
			break
		end

		task.wait(2)
	end
end

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(character)
		task.spawn(CheckCharacter, player, character)
	end)
end)

for _, player in ipairs(Players:GetPlayers()) do
	if player.Character then
		task.spawn(CheckCharacter, player, player.Character)
	end

	player.CharacterAdded:Connect(function(character)
		task.spawn(CheckCharacter, player, character)
	end)
end

if Players.LocalPlayer then
	task.spawn(function()
		StartGuiDetection(Players.LocalPlayer)
	end)
end
