local Tool = script.Parent

local EquipAnimation = Instance.new("Animation")
EquipAnimation.AnimationId = "rbxassetid://ID_DA_ANIMACAO_EQUIPAR"

local UnequipAnimation = Instance.new("Animation")
UnequipAnimation.AnimationId = "rbxassetid://ID_DA_ANIMACAO_DESEQUIPAR"

local EquipTrack
local UnequipTrack

Tool.Equipped:Connect(function()
	local Character = Tool.Parent
	local Humanoid = Character:FindFirstChildOfClass("Humanoid")

	if Humanoid then
		EquipTrack = Humanoid:LoadAnimation(EquipAnimation)
		EquipTrack:Play()
	end
end)

Tool.Unequipped:Connect(function()
	local Character = Tool.Parent
	local Humanoid = Character:FindFirstChildOfClass("Humanoid")

	if Humanoid then
		UnequipTrack = Humanoid:LoadAnimation(UnequipAnimation)
		UnequipTrack:Play()
	end
end)
