local Players = game:GetService("Players")

local admins = {
	["kit_cynALT"] = true,
	["Admin1"] = true,
	["Admin2"] = true,
	["Admin3"] = true,
	["Admin4"] = true
}

local function getPlayer(str)
	if not str then return nil end
	str = str:lower()

	for _, v in ipairs(Players:GetPlayers()) do
		if v.Name:lower():find(str, 1, true) or v.DisplayName:lower():find(str, 1, true) then
			return v
		end
	end
end

local function getChar(plr)
	return plr.Character
end

local function getRoot(char)
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum(char)
	return char and char:FindFirstChildOfClass("Humanoid")
end

local function isAdmin(plr)
	return admins[plr.Name] == true
end

local function fling(char)
	local root = getRoot(char)
	if not root then return end

	local bv = Instance.new("BodyVelocity")
	bv.Velocity = Vector3.new(math.random(-500,500), math.random(200,600), math.random(-500,500))
	bv.MaxForce = Vector3.new(1e9,1e9,1e9)
	bv.Parent = root

	task.delay(0.25, function()
		bv:Destroy()
	end)
end

local function handleCommand(plr, msg)
	if not isAdmin(plr) then return end
	if msg:sub(1,1) ~= ":" then return end

	local args = msg:sub(2):split(" ")
	local cmd = args[1]
	local targetStr = args[2]
	local target = getPlayer(targetStr)

	if cmd == "kill" and target then
		local hum = getHum(getChar(target))
		if hum then hum.Health = 0 end
	end

	if cmd == "bring" and target then
		local root1 = getRoot(getChar(plr))
		local root2 = getRoot(getChar(target))
		if root1 and root2 then
			root2.CFrame = root1.CFrame * CFrame.new(2,0,0)
		end
	end

	if cmd == "kick" and target then
		target:Kick("Kicked by admin")
	end

	if cmd == "sit" and target then
		local hum = getHum(getChar(target))
		if hum then hum.Sit = true end
	end

	if cmd == "fling" and target then
		fling(getChar(target))
	end

	if cmd == "freeze" and target then
		local char = getChar(target)
		local root = getRoot(char)
		if root then root.Anchored = true end
	end

	if cmd == "unfreeze" and target then
		local char = getChar(target)
		local root = getRoot(char)
		if root then root.Anchored = false end
	end
end

Players.PlayerAdded:Connect(function(plr)
	plr.Chatted:Connect(function(msg)
		handleCommand(plr, msg)
	end)
end)
