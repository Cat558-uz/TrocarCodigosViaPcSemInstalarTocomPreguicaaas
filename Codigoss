local function openPanel(plr)
	if not isAllowed(LocalPlayer) then return end

	selectedPlayer = plr
	panel.Visible = true
	panel.Size = UDim2.new(0,0,0,0)

	playerText.Text = plr.DisplayName
	subText.Text = "@"..plr.Name

	local img = Players:GetUserThumbnailAsync(plr.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size180x180)
	avatar.Image = img

	TweenService:Create(panel, TweenInfo.new(0.18), {
		Size = UDim2.new(0,220,0,360)
	}):Play()
end

Mouse.Button1Down:Connect(function()
	if not isAllowed(LocalPlayer) then return end

	local target = Mouse.Target
	if not target then return end

	local model = target:FindFirstAncestorOfClass("Model")
	if not model then return end

	local plr = Players:GetPlayerFromCharacter(model)
	if plr and plr ~= LocalPlayer then
		openPanel(plr)
	end
end)

Players.PlayerRemoving:Connect(function(plr)
	if plr == selectedPlayer then
		closePanel()
	end
end)

local dragging, startPos, dragStart

top.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = panel.Position
	end
end)

top.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		panel.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)
