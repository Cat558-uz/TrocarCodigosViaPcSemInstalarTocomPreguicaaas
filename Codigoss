local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local Camera = workspace.CurrentCamera

local allowedUsers = {
	["kit_cynALT"] = true,
	["Xingling858"] = true,
	[23456789] = true,
	[34567890] = true,
	[45678901] = true,
	[56789012] = true
}

local function isAllowed(plr)
	return allowedUsers[plr.Name] == true or allowedUsers[plr.UserId] == true
end

pcall(function()
	CoreGui:FindFirstChild("PlayerPanelGui"):Destroy()
end)

local gui = Instance.new("ScreenGui")
gui.Name = "PlayerPanelGui"
gui.ResetOnSpawn = false
gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
gui.Parent = CoreGui

local selectedPlayer
local viewing = false

local function getChar(plr)
	return plr.Character
end

local function getRoot(char)
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHum(char)
	return char and char:FindFirstChildOfClass("Humanoid")
end

local function kill(plr)
	local hum = getHum(getChar(plr))
	if hum then hum.Health = 0 end
end

local function bring(plr)
	local char = getChar(plr)
	local root = getRoot(char)
	local myRoot = getRoot(getChar(LocalPlayer))
	if root and myRoot then
		root.CFrame = myRoot.CFrame * CFrame.new(2,0,0)
	end
end

local function void(plr)
	local root = getRoot(getChar(plr))
	if root then
		root.CFrame = CFrame.new(0, -5000, 0)
	end
end

local function fling(plr)
	local root = getRoot(getChar(plr))
	if root then
		local bv = Instance.new("BodyVelocity")
		bv.Velocity = Vector3.new(99999,99999,99999)
		bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		bv.Parent = root
		game.Debris:AddItem(bv, 0.5)
	end
end

local function sit(plr)
	local hum = getHum(getChar(plr))
	if hum then hum.Sit = true end
end

local function freeze(plr)
	local root = getRoot(getChar(plr))
	if root then root.Anchored = true end
end

local function unfreeze(plr)
	local root = getRoot(getChar(plr))
	if root then root.Anchored = false end
end

local function kick(plr, reason)
	plr:Kick(reason or "Kicked")
end

local function createButton(parent, text, callback)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(1,-8,0,34)
	b.BackgroundColor3 = Color3.fromRGB(28,28,28)
	b.Text = text
	b.TextColor3 = Color3.new(1,1,1)
	b.Font = Enum.Font.GothamSemibold
	b.TextSize = 13
	b.Parent = parent

	local c = Instance.new("UICorner", b)
	c.CornerRadius = UDim.new(0,10)

	b.MouseButton1Click:Connect(function()
		if selectedPlayer then
			callback(selectedPlayer)
		end
	end)

	return b
end

local panel = Instance.new("Frame")
panel.Size = UDim2.new(0,220,0,360)
panel.Position = UDim2.new(1,-235,0.5,-180)
panel.BackgroundColor3 = Color3.fromRGB(20,20,20)
panel.Parent = gui

local scroll = Instance.new("ScrollingFrame")
scroll.Size = UDim2.new(1,-10,1,-10)
scroll.Position = UDim2.new(0,5,0,5)
scroll.Parent = panel

local layout = Instance.new("UIListLayout", scroll)

createButton(scroll,"Kill",kill)
createButton(scroll,"Bring",bring)
createButton(scroll,"Void",void)
createButton(scroll,"Fling",fling)
createButton(scroll,"Sit",sit)
createButton(scroll,"Freeze",freeze)
createButton(scroll,"Unfreeze",unfreeze)
createButton(scroll,"Kick",function(plr)
	kick(plr, "Admin command")
end)

Mouse.Button1Down:Connect(function()
	if not isAllowed(LocalPlayer) then return end

	local target = Mouse.Target
	if not target then return end

	local model = target:FindFirstAncestorOfClass("Model")
	if not model then return end

	local plr = Players:GetPlayerFromCharacter(model)
	if plr and plr ~= LocalPlayer then
		selectedPlayer = plr
	end
end)
